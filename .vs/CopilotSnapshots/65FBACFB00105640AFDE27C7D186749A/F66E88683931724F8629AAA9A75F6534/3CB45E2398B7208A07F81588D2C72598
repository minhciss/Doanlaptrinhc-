using Android.Media;
using CommunityToolkit.Maui.Alerts;
using CommunityToolkit.Maui.Core;
using VinhKhanhapp.Models;

namespace VinhKhanhapp.Services;

public interface IAudioService
{
    Task PlayPoiAsync(Poi poi, string language, CancellationToken cancellationToken = default);
}

public interface IPoiRepository
{
    Task<IReadOnlyList<Poi>> GetPoisAsync(CancellationToken cancellationToken = default);
    Task<Poi?> GetPoiByCodeAsync(string code, CancellationToken cancellationToken = default);
}

public interface IAnalyticsService
{
    Task LogPoiPlayedAsync(Poi poi, string language, TimeSpan duration, CancellationToken cancellationToken = default);
}

public class AudioService : IAudioService
{
    MediaPlayer? player;

    public async Task PlayPoiAsync(Poi poi, string language, CancellationToken cancellationToken = default)
    {
        PoiTranslation? translation = poi.Translations
            .FirstOrDefault(t => t.Language == language)
            ?? poi.Translations.FirstOrDefault();

        if (translation == null)
            return;

        Console.WriteLine("Audio file: " + translation.AudioFile);

        // Nếu có file audio thì phát
        if (!string.IsNullOrWhiteSpace(translation.AudioFile))
        {
            await PlayAudio(translation.AudioFile);
            return;
        }

        // Nếu không có audio → dùng TextToSpeech
        var text = translation.TtsScript ?? translation.Description;

        if (!string.IsNullOrWhiteSpace(text))
        {
            await TextToSpeech.Default.SpeakAsync(text, null, cancellationToken);
        }
    }

    async Task PlayAudio(string file)
    {
        try
        {
            Console.WriteLine("Playing audio: " + file);

            var stream = await FileSystem.OpenAppPackageFileAsync(file);

            var tempFile = Path.Combine(FileSystem.CacheDirectory, file);

            using (var fs = File.Create(tempFile))
            {
                await stream.CopyToAsync(fs);
            }

            player?.Release();
            player = new MediaPlayer();

            player.SetDataSource(tempFile);

            player.Prepared += (s, e) =>
            {
                player.Start();
            };

            player.PrepareAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Audio error: " + ex.Message);
        }
    }
}

