public class AnalyticsService : IAnalyticsService
{
    public Task LogPoiPlayedAsync(Poi poi, string language, TimeSpan duration, CancellationToken cancellationToken = default)
    {
        var message = $"Đã nghe: {poi.Translations.FirstOrDefault(t => t.Language == language)?.Title ?? poi.Id}";
        var toast = Toast.Make(message, ToastDuration.Short);

        return toast.Show(cancellationToken);
    }
}