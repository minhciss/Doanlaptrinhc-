public class AnalyticsService : IAnalyticsService
{
    public Task LogPoiPlayedAsync(Poi poi, string language, TimeSpan duration, CancellationToken cancellationToken = default)
    {
        var title = poi.Translations.FirstOrDefault(t => t.Language == language)?.Title ?? poi.Id;
        return MainThread.InvokeOnMainThreadAsync(() => {
            Toast.Make($"Đã nghe: {title}", ToastDuration.Short).Show(cancellationToken);
        });
    }
}