<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VinhKhanhTour.MarkupExtensions"
             x:Class="VinhKhanhTour.Pages.SettingsPage"
             Title="{local:Translate 'Cài đặt'}"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">

    <ScrollView>
        <VerticalStackLayout Spacing="{OnIdiom Phone=16, Tablet=24, Desktop=24}" 
                             Padding="{OnIdiom Phone=20, Tablet=40, Desktop=80}"
                             MaximumWidthRequest="800"
                             HorizontalOptions="Center">
                  
            <!-- 🌐 Ngôn ngữ Section -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                    <Label Grid.Column="0" Text="🌐" FontSize="22" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="{local:Translate 'Ngôn ngữ / Language'}" VerticalOptions="Center" VerticalTextAlignment="Center" LineBreakMode="WordWrap" />
                    
                    <Picker Grid.Column="2" x:Name="LanguagePicker"
                            Title="Ngôn ngữ"
                            WidthRequest="{OnIdiom Phone=130, Tablet=200, Desktop=200}"
                            HorizontalOptions="End" VerticalOptions="Center"
                            SelectedIndexChanged="OnLanguageChanged">
                        <Picker.Items>
                            <x:String>Tiếng Việt</x:String>
                            <x:String>English</x:String>
                            <x:String>Español</x:String>
                            <x:String>Français</x:String>
                            <x:String>Deutsch</x:String>
                            <x:String>中文</x:String>
                            <x:String>日本語</x:String>
                            <x:String>한국어</x:String>
                            <x:String>Русский</x:String>
                            <x:String>Italiano</x:String>
                            <x:String>Português</x:String>
                            <x:String>हिन्दी</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>
            </Border>

            <!-- 🔊 Âm thanh Section -->
            <HorizontalStackLayout Spacing="8" Margin="0,8,0,0">
                <Label Text="🔊" FontSize="20" VerticalOptions="Center" />
                <Label Text="{local:Translate 'Âm thanh &amp; Giọng đọc'}" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{local:Translate 'Tốc độ đọc (TTS)'}" FontAttributes="Bold" />
                    <Slider x:Name="SpeechRateSlider" 
                            Maximum="2.0" Minimum="0.5" Value="1.0" 
                            ValueChanged="OnSpeechRateChanged"
                            MinimumTrackColor="{StaticResource Primary}"
                            MaximumTrackColor="{StaticResource Gray200}"
                            ThumbColor="{StaticResource Primary}" />
                    <Label x:Name="SpeechRateLabel" 
                           Text="Bình thường (1.0x)" 
                           FontSize="12" TextColor="{StaticResource Gray400}" 
                           HorizontalOptions="End" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
