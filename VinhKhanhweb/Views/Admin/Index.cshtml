@model List<Poi>

<div class="card shadow-sm bg-white text-dark">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">📍 Danh sách POI</h5>
        <a href="/Admin/Create" class="btn btn-primary btn-sm">
            ➕ Thêm mới
        </a>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tên</th>
                    <th>Mô tả</th>
                    <th>Địa chỉ</th>
                    <th>Trạng thái</th>
                    <th style="width:250px;">Hành động</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Name</td>
                        <td>@item.Description</td>
                        <td>@item.Address</td>

                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Tắt</span>
                            }
                        </td>

                        <td>
                            <a href="/Admin/Edit/@item.Id"
                                   class="btn btn-warning btn-sm me-1">
                                ✏
                            </a>

                            <a href="/Admin/Delete/@item.Id"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Xóa thật không?')">
                                🗑
                            </a>

                            @if (item.IsActive)
                            {
                                <a href="/Admin/Toggle/@item.Id"
                                       class="btn btn-outline-secondary btn-sm">
                                    ⛔
                                </a>
                            }
                            else
                            {
                                <a href="/Admin/Toggle/@item.Id"
                                       class="btn btn-outline-success btn-sm">
                                    ✅
                                </a>
                            }
                            <td>
                                <img src="http://192.168.1.11:7170/Poi/Qr/@item.Id" width="100" />
                            </td>
                           
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>