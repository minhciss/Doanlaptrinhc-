<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Minh2.MainPage"
             Title="Thuyết minh Vĩnh Khánh (POC)">

    <Grid RowDefinitions="Auto, Auto, *, Auto"
          Padding="16"
          ColumnSpacing="12"
          RowSpacing="12">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
            <VerticalStackLayout Spacing="2">
                <Label Text="Thuyết minh tự động"
                       FontSize="20"
                       FontAttributes="Bold"/>
                <Label Text="Phố ẩm thực Vĩnh Khánh — POC"
                       FontSize="12"
                       TextColor="Gray"/>
            </VerticalStackLayout>

            <Button Text="⚙"
                    WidthRequest="44"
                    HeightRequest="44"
                    VerticalOptions="Center"
                    HorizontalOptions="End"
                    Clicked="OnSettingsClicked" />
        </Grid>

        <!-- Status -->
        <HorizontalStackLayout Grid.Row="1"
                               Spacing="12"
                               VerticalOptions="Center">
            <Label x:Name="StatusLabel"
                   Text="Stopped"
                   FontAttributes="Bold" />
            <Label Text="·"
                   TextColor="Gray" />
            <Label x:Name="NearestPoiLabel"
                   Text="Nearest: (none)"
                   LineBreakMode="TailTruncation"/>
            <Label x:Name="NearestDistLabel"
                   Text=""
                   TextColor="Gray"
                   FontSize="12"/>
        </HorizontalStackLayout>

        <!-- Map preview + POI list -->
        <Grid Grid.Row="2"
              ColumnDefinitions="2*, 1*"
              ColumnSpacing="12">

            <!-- Map placeholder -->
            <Border Stroke="#e0e0e0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="#f7f9fb"
                    Padding="12">

                <Grid>
                    <Label Text="Map preview (add Microsoft.Maui.Controls.Maps to show real map)"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="Gray" />
                </Grid>
            </Border>

            <!-- POI list -->
            <Border Grid.Column="1"
                    Stroke="#e0e0e0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="White"
                    Padding="0">

                <VerticalStackLayout Padding="8"
                                     Spacing="8">

                    <Label Text="Danh sách điểm (POI)"
                           FontAttributes="Bold" />

                    <CollectionView x:Name="PoiList"
                                    SelectionMode="Single"
                                    SelectionChanged="PoiList_SelectionChanged">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Border Padding="8"
                                        Stroke="#f0f0f0"
                                        StrokeShape="RoundRectangle 6"
                                        BackgroundColor="Transparent"
                                        Margin="2">

                                    <Grid ColumnDefinitions="*, Auto"
                                          RowDefinitions="Auto, Auto">

                                        <Label Grid.Row="0"
                                               Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontAttributes="Bold" />

                                        <Label Grid.Row="1"
                                               Grid.Column="0"
                                               Text="{Binding Description}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2"
                                               FontSize="12"
                                               TextColor="Gray" />
                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Controls -->
        <Border Grid.Row="3"
                StrokeThickness="0"
                BackgroundColor="Transparent"
                Padding="4">

            <Grid ColumnDefinitions="*, Auto, Auto"
                  ColumnSpacing="12">

                <HorizontalStackLayout VerticalOptions="Center"
                                       Spacing="8">

                    <Button x:Name="StartBtn"
                            Text="Start Tracking"
                            Clicked="OnStartClicked" />

                    <Button x:Name="StopBtn"
                            Text="Stop Tracking"
                            Clicked="OnStopClicked"
                            IsEnabled="False" />

                </HorizontalStackLayout>

                <Button x:Name="PlayPoiBtn"
                        Grid.Column="1"
                        Text="Play Description"
                        Clicked="OnPlayPoi"
                        IsEnabled="False"
                        HorizontalOptions="End" />

                <Button Grid.Column="2"
                        Text="QR"
                        Clicked="OnScanQr"
                        HorizontalOptions="End" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>